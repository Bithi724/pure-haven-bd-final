"use client";

import Link from "next/link";
import { ChevronLeft, ChevronRight } from "lucide-react";
import { useEffect, useMemo, useRef, useState } from "react";

type Subcategory = {
  id: number;
  name: string;
  slug: string;
};

type Category = {
  id: number;
  name: string;
  slug: string;
  image?: string | null;
  subcategories: Subcategory[];
};

type Product = {
  id: number;
  name: string;
  image: string;
  category: string;
  subcategory?: string | null;
};

const fallbackImages: Record<string, string> = {
  cosmetics:
    "https://images.unsplash.com/photo-1596462502278-27bfdc403348?q=80&w=1200&auto=format&fit=crop",
  haircare:
    "https://images.unsplash.com/photo-1522338140262-f46f5913618a?q=80&w=1200&auto=format&fit=crop",
  skincare:
    "https://images.unsplash.com/photo-1556228578-8c89e6adf883?q=80&w=1200&auto=format&fit=crop",
  perfume:
    "https://images.unsplash.com/photo-1541643600914-78b084683601?q=80&w=1200&auto=format&fit=crop",
  food:
    "https://images.unsplash.com/photo-1587049352851-8d4e89133924?q=80&w=1200&auto=format&fit=crop",
  "mens-products":
    "https://images.unsplash.com/photo-1516826957135-700dedea698c?q=80&w=1200&auto=format&fit=crop",
  "baby-products":
    "https://images.unsplash.com/photo-1515488042361-ee00e0ddd4e4?q=80&w=1200&auto=format&fit=crop",
};

const defaultFallback =
  "https://images.unsplash.com/photo-1471193945509-9ad0617afabf?q=80&w=1200&auto=format&fit=crop";

function slug(value?: string | null) {
  return (value || "").trim().toLowerCase().replace(/\s+/g, "-");
}

function categoryImage(category: Category, products: Product[]) {
  if (category.image) return category.image;

  const matchedProduct = products.find(
    (product) => slug(product.category) === category.slug && product.image
  );

  return matchedProduct?.image || fallbackImages[category.slug] || defaultFallback;
}

function subcategoryImage(category: Category, subcategory: Subcategory, products: Product[]) {
  const matchedProduct = products.find(
    (product) =>
      slug(product.category) === category.slug &&
      slug(product.subcategory) === subcategory.slug &&
      product.image
  );

  return matchedProduct?.image || categoryImage(category, products);
}

export default function CategorySection() {
  const [categories, setCategories] = useState<Category[]>([]);
  const [products, setProducts] = useState<Product[]>([]);
  const [loading, setLoading] = useState(true);
  const topScrollRef = useRef<HTMLDivElement | null>(null);

  useEffect(() => {
    async function loadData() {
      try {
        const [categoryRes, productRes] = await Promise.all([
          fetch("/api/categories", { cache: "no-store" }),
          fetch("/api/products", { cache: "no-store" }),
        ]);

        const categoryData = await categoryRes.json();
        const productData = await productRes.json();

        setCategories(
          categoryRes.ok && categoryData?.success && Array.isArray(categoryData.categories)
            ? categoryData.categories
            : []
        );

        setProducts(
          productRes.ok && productData?.success && Array.isArray(productData.products)
            ? productData.products
            : []
        );
      } catch {
        setCategories([]);
        setProducts([]);
      } finally {
        setLoading(false);
      }
    }

    loadData();
  }, []);

  const visibleCategories = useMemo(
    () => categories.filter((category) => category.slug !== "essentials"),
    [categories]
  );

  function scrollTopCategories(direction: "left" | "right") {
    topScrollRef.current?.scrollBy({
      left: direction === "left" ? -420 : 420,
      behavior: "smooth",
    });
  }

  if (loading) {
    return (
      <section className="section-gap">
        <div className="container-ph">
          <div className="h-8 w-56 animate-pulse rounded-full bg-[#ead9d1]" />
          <div className="mt-6 grid grid-cols-2 gap-5 lg:grid-cols-4">
            {Array.from({ length: 4 }).map((_, index) => (
              <div
                key={index}
                className="h-[300px] animate-pulse rounded-[28px] bg-[#f3e7e1]"
              />
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (visibleCategories.length === 0) return null;

  return (
    <section className="section-gap">
      <div className="container-ph">
        <div className="mb-6 flex items-center justify-between gap-4">
          <h2 className="text-3xl font-semibold text-[#2e221d]">
            Shop by Category
          </h2>

          <div className="flex items-center gap-3">
            <Link
              href="/shop"
              className="hidden text-xs font-semibold uppercase tracking-[0.24em] text-[#2e221d] hover:text-[#7a5244] sm:inline"
            >
              Explore All
            </Link>

            <button
              type="button"
              onClick={() => scrollTopCategories("left")}
              className="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#ead9d1] bg-white text-[#2e221d] hover:bg-[#f8f3ef]"
              aria-label="Scroll categories left"
            >
              <ChevronLeft className="h-4 w-4" />
            </button>

            <button
              type="button"
              onClick={() => scrollTopCategories("right")}
              className="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[#ead9d1] bg-white text-[#2e221d] hover:bg-[#f8f3ef]"
              aria-label="Scroll categories right"
            >
              <ChevronRight className="h-4 w-4" />
            </button>
          </div>
        </div>

        <div
          ref={topScrollRef}
          className="flex gap-5 overflow-x-auto pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
        >
          {visibleCategories.map((category) => (
            <Link
              key={category.id}
              href={`/shop?category=${category.slug}`}
              className="relative h-[300px] w-[300px] shrink-0 overflow-hidden rounded-[28px] border border-[#ead9d1] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md lg:w-[360px]"
            >
              <img
                src={categoryImage(category, products)}
                alt={category.name}
                className="h-full w-full object-cover"
              />

              <div className="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent" />

              <div className="absolute bottom-6 left-6 text-white">
                <p className="text-xs uppercase tracking-[0.28em]">
                  Collection
                </p>
                <h3 className="mt-2 text-3xl font-semibold">
                  {category.name}
                </h3>
              </div>
            </Link>
          ))}
        </div>

        <div className="mt-14 space-y-14">
          {visibleCategories
            .filter((category) => category.subcategories.length > 0)
            .map((category) => (
              <div key={category.id}>
                <div className="mb-6 flex items-end justify-between gap-4">
                  <div>
                    <p className="text-sm uppercase tracking-[0.28em] text-[#7a5244]">
                      Shop {category.name}
                    </p>
                    <h2 className="mt-2 text-3xl font-semibold text-[#2e221d]">
                      {category.name}
                    </h2>
                  </div>

                  <Link
                    href={`/shop?category=${category.slug}`}
                    className="text-xs font-semibold uppercase tracking-[0.24em] text-[#2e221d] hover:text-[#7a5244]"
                  >
                    View All
                  </Link>
                </div>

                <div className="flex gap-5 overflow-x-auto pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
                  {category.subcategories.map((subcategory) => (
                    <Link
                      key={subcategory.id}
                      href={`/shop?category=${category.slug}&subcategory=${subcategory.slug}`}
                      className="relative h-[300px] w-[260px] shrink-0 overflow-hidden rounded-[28px] border border-[#ead9d1] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md lg:w-[310px]"
                    >
                      <img
                        src={subcategoryImage(category, subcategory, products)}
                        alt={subcategory.name}
                        className="h-full w-full object-cover"
                      />

                      <div className="absolute inset-0 bg-gradient-to-t from-black/65 via-black/10 to-transparent" />

                      <div className="absolute bottom-6 left-6 text-white">
                        <p className="text-xs uppercase tracking-[0.28em]">
                          Subcategory
                        </p>
                        <h3 className="mt-2 text-2xl font-semibold">
                          {subcategory.name}
                        </h3>
                      </div>
                    </Link>
                  ))}
                </div>
              </div>
            ))}
        </div>
      </div>
    </section>
  );
}