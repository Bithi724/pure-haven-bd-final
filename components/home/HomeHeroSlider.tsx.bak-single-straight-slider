function SlideCard({
  slide,
  active,
  size = "large",
}: {
  slide: Slide;
  active: boolean;
  size?: "large" | "small";
}) {
  return (
    <div
      className={`absolute inset-0 transition-all duration-700 ease-out ${
        active
          ? "translate-x-0 opacity-100"
          : "translate-x-full opacity-0 pointer-events-none"
      }`}
    >
      <div className="relative h-full w-full overflow-hidden rounded-[26px]">
        <img
          src={slide.image}
          alt={slide.title}
          className="h-full w-full object-cover"
        />

        <div className="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent" />

        <div
          className={`absolute left-0 right-0 bottom-0 text-white ${
            size === "large" ? "p-6 sm:p-7 lg:p-8" : "p-4 sm:p-5"
          }`}
        >
          <p
            className={`mb-2 uppercase tracking-[0.18em] text-white/85 ${
              size === "large" ? "text-[11px] sm:text-xs" : "text-[10px]"
            }`}
          >
            {slide.eyebrow}
          </p>

          <h3
            className={`font-semibold leading-tight ${
              size === "large"
                ? "mb-2 text-2xl sm:text-3xl lg:text-4xl"
                : "mb-1 text-lg sm:text-xl"
            }`}
          >
            {slide.title}
          </h3>

          <p
            className={`text-white/90 ${
              size === "large"
                ? "mb-4 max-w-[460px] text-sm sm:text-base"
                : "mb-3 text-xs sm:text-sm"
            }`}
          >
            {slide.subtitle}
          </p>

          <Link
            href={slide.href}
            className="inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-semibold text-[#2e221d] transition hover:bg-[#f5ede8]"
          >
            {slide.buttonText}
          </Link>
        </div>
      </div>
    </div>
  );
}

export default function HomeHeroSlider() {
  const [activeIndex, setActiveIndex] = useState(0);

  useEffect(() => {
    const timer = window.setInterval(() => {
      setActiveIndex((prev) => (prev + 1) % slides.length);
    }, 4500);

    return () => window.clearInterval(timer);
  }, []);

  const goPrev = () => {
    setActiveIndex((prev) => (prev - 1 + slides.length) % slides.length);
  };

  const goNext = () => {
    setActiveIndex((prev) => (prev + 1) % slides.length);
  };

  const mainSlide = slides[activeIndex];
  const sideSlides = [
    slides[(activeIndex + 1) % slides.length],
    slides[(activeIndex + 2) % slides.length],
    slides[(activeIndex + 3) % slides.length],
  ];

  return (
    <section className="mx-auto w-full max-w-[1400px] px-4 pb-8 pt-6 md:px-6 lg:px-8">
      <div className="relative">
        <div className="grid gap-5 lg:grid-cols-[1.15fr_0.95fr]">
          {/* Left big square-like box */}
          <div className="relative min-h-[320px] overflow-hidden rounded-[28px] bg-[#f8f3ef] sm:min-h-[420px] lg:min-h-[560px]">
            <SlideCard slide={mainSlide} active={true} size="large" />
          </div>

          {/* Right stacked grid */}
          <div className="grid gap-5 sm:grid-cols-2 lg:grid-cols-1">
            {sideSlides.map((slide) => (
              <div
                key={slide.id}
                className="relative min-h-[170px] overflow-hidden rounded-[26px] bg-[#f8f3ef] sm:min-h-[210px] lg:min-h-[173px]"
              >
                <SlideCard slide={slide} active={true} size="small" />
              </div>
            ))}
          </div>
        </div>

        {/* Arrows */}
        <button
          type="button"
          onClick={goPrev}
          aria-label="Previous slide"
          className="absolute left-3 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-[#2e221d] shadow-md transition hover:bg-white"
        >
          <ChevronLeft className="h-5 w-5" />
        </button>

        <button
          type="button"
          onClick={goNext}
          aria-label="Next slide"
          className="absolute right-3 top-1/2 z-20 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-[#2e221d] shadow-md transition hover:bg-white"
        >
          <ChevronRight className="h-5 w-5" />
        </button>

        {/* Dots */}
        <div className="mt-5 flex justify-center gap-2">
          {slides.map((slide, index) => (
            <button
              key={slide.id}
              type="button"
              aria-label={`Go to slide ${index + 1}`}
              onClick={() => setActiveIndex(index)}
              className={`h-2.5 rounded-full transition-all ${
                activeIndex === index
                  ? "w-8 bg-[#2e221d]"
                  : "w-2.5 bg-[#d5c3b9] hover:bg-[#bda295]"
              }`}
            />
          ))}
        </div>
      </div>
    </section>
  );
}