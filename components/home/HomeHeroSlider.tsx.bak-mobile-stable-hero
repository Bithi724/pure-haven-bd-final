"use client";

import Link from "next/link";
import { useEffect, useMemo, useState } from "react";

type HomePromo = {
  id: string;
  label: string;
  title: string;
  subtitle: string;
  image: string;
  href: string;
  isActive: boolean;
  sortOrder: number;
};

const fallbackSlides: HomePromo[] = [
  {
    id: "fallback-1",
    label: "New Arrivals",
    title: "Fresh Beauty Collection",
    subtitle: "Explore cosmetics, skincare, haircare, and daily essentials.",
    image: "/images/categories/cosmetics.jpg",
    href: "/shop",
    isActive: true,
    sortOrder: 1,
  },
];

export default function HomeHeroSlider() {
  const [items, setItems] = useState<HomePromo[]>(fallbackSlides);
  const [active, setActive] = useState(0);

  useEffect(() => {
    async function loadSlides() {
      try {
        const res = await fetch("/api/home-promos?kind=slider", {
          cache: "no-store",
        });
        const data = await res.json();

        if (res.ok && data?.success && Array.isArray(data.items)) {
          const activeItems = data.items
            .filter((item: HomePromo) => item.isActive)
            .sort((a: HomePromo, b: HomePromo) => a.sortOrder - b.sortOrder);

          if (activeItems.length > 0) setItems(activeItems);
        }
      } catch {}
    }

    loadSlides();
  }, []);

  const slides = useMemo(() => items.length > 0 ? items : fallbackSlides, [items]);

  useEffect(() => {
    const timer = window.setInterval(() => {
      setActive((prev) => (prev + 1) % slides.length);
    }, 4200);

    return () => window.clearInterval(timer);
  }, [slides.length]);

  return (
    <section className="bg-[#fcf8f6] px-3 pt-4 md:px-6 lg:px-8">
      <div className="mx-auto max-w-7xl overflow-hidden rounded-[22px] border border-[#ead9d1] bg-[#2e221d] md:rounded-[30px]">
        <div
          className="flex transition-transform duration-700 ease-out"
          style={{ transform: `translateX(-${active * 100}%)` }}
        >
          {slides.map((slide) => (
            <Link
              key={slide.id}
              href={slide.href || "/shop"}
              className="relative h-[235px] w-full shrink-0 overflow-hidden sm:h-[310px] md:h-[430px]"
            >
              <img
                src={slide.image}
                alt={slide.title}
                className="absolute inset-0 h-full w-full object-cover"
              />

              <div className="absolute inset-0 bg-gradient-to-r from-black/75 via-black/30 to-black/5" />

              <div className="relative z-10 flex h-full max-w-xl flex-col justify-center px-6 text-white sm:px-10 md:px-14">
                <p className="text-[10px] font-semibold uppercase tracking-[0.32em] text-white/80 sm:text-xs">
                  {slide.label}
                </p>

                <h1 className="mt-3 text-3xl font-semibold leading-tight sm:text-5xl md:text-6xl">
                  {slide.title}
                </h1>

                {slide.subtitle ? (
                  <p className="mt-3 max-w-md text-xs leading-5 text-white/85 sm:text-sm md:text-base md:leading-7">
                    {slide.subtitle}
                  </p>
                ) : null}

                <span className="mt-5 w-fit rounded-full bg-white px-5 py-2 text-xs font-bold text-[#2e221d] sm:px-7 sm:py-3 sm:text-sm">
                  Shop now
                </span>
              </div>
            </Link>
          ))}
        </div>

        <div className="relative -mt-8 mb-4 flex justify-center gap-2">
          {slides.map((_, index) => (
            <button
              key={index}
              type="button"
              onClick={() => setActive(index)}
              className={`h-2 rounded-full transition-all ${
                active === index ? "w-8 bg-white" : "w-2 bg-white/50"
              }`}
            />
          ))}
        </div>
      </div>
    </section>
  );
}