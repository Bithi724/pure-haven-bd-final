"use client";

import Link from "next/link";
import { useEffect, useState } from "react";
import SiteLogo from "@/components/layout/SiteLogo";

type Subcategory = {
  id: number;
  name: string;
  slug: string;
};

type Category = {
  id: number;
  name: string;
  slug: string;
  subcategories?: Subcategory[];
};

export default function Navbar() {
  const [categories, setCategories] = useState<Category[]>([]);
  const [openMenu, setOpenMenu] = useState(false);

  useEffect(() => {
    async function loadCategories() {
      try {
        const res = await fetch("/api/categories", { cache: "no-store" });
        const data = await res.json();

        if (res.ok && data?.success && Array.isArray(data.categories)) {
          setCategories(data.categories);
        }
      } catch {
        setCategories([]);
      }
    }

    loadCategories();
  }, []);

  function closeMenu() {
    setOpenMenu(false);
  }

  return (
    <header className="sticky top-0 z-50 border-b border-[#ead9d1] bg-white/95 backdrop-blur">
      <div className="container-ph">
        <div className="flex h-20 items-center justify-between gap-4">
          <button
            type="button"
            onClick={() => setOpenMenu((prev) => !prev)}
            className="grid h-11 w-11 place-items-center border border-[#ead9d1] text-2xl text-[#2e221d] lg:hidden"
            aria-label="Open menu"
          >
            {openMenu ? "×" : "☰"}
          </button>

          <div className="hidden lg:block lg:w-[220px]" />

          <div className="flex flex-1 justify-center">
            <SiteLogo />
          </div>

          <div className="flex items-center justify-end gap-2 lg:w-[220px]">
            <Link
              href="/shop"
              className="grid h-11 w-11 place-items-center border border-[#ead9d1] text-xl hover:bg-[#f8f3ef]"
              aria-label="Search"
            >
              🔍
            </Link>

            <Link
              href="/wishlist"
              className="grid h-11 w-11 place-items-center border border-[#ead9d1] text-xl hover:bg-[#f8f3ef]"
              aria-label="Wishlist"
            >
              ♡
            </Link>

            <Link
              href="/cart"
              className="grid h-11 w-11 place-items-center border border-[#ead9d1] text-xl hover:bg-[#f8f3ef]"
              aria-label="Cart"
            >
              🛒
            </Link>

            <Link
              href="/login"
              className="hidden h-11 w-11 place-items-center border border-[#ead9d1] text-xl hover:bg-[#f8f3ef] sm:grid"
              aria-label="Account"
            >
              ♙
            </Link>
          </div>
        </div>

        <nav className="hidden border-t border-[#ead9d1] lg:block">
          <div className="flex items-center justify-center gap-8 py-4 text-sm font-medium text-[#2e221d]">
            <Link href="/shop" className="hover:text-[#7a5244]">
              All Products
            </Link>

            {categories.map((category) => (
              <div key={category.id} className="group relative">
                <Link
                  href={`/shop?category=${category.slug}`}
                  className="inline-flex items-center gap-1 hover:text-[#7a5244]"
                >
                  {category.name}
                  {category.subcategories && category.subcategories.length > 0 ? (
                    <span className="text-xs">⌄</span>
                  ) : null}
                </Link>

                {category.subcategories && category.subcategories.length > 0 ? (
                  <div className="invisible absolute left-0 top-full min-w-56 translate-y-2 rounded-2xl border border-[#ead9d1] bg-white p-3 opacity-0 shadow-lg transition group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                    {category.subcategories.map((sub) => (
                      <Link
                        key={sub.id}
                        href={`/shop?category=${category.slug}&subcategory=${sub.slug}`}
                        className="block rounded-xl px-4 py-2 text-sm hover:bg-[#f8f3ef]"
                      >
                        {sub.name}
                      </Link>
                    ))}
                  </div>
                ) : null}
              </div>
            ))}

            <Link href="/track-order" className="hover:text-[#7a5244]">
              Track Order
            </Link>
          </div>
        </nav>

        {openMenu ? (
          <div className="border-t border-[#ead9d1] py-4 lg:hidden">
            <div className="grid gap-2">
              <Link
                href="/shop"
                onClick={closeMenu}
                className="rounded-xl px-4 py-3 font-semibold hover:bg-[#f8f3ef]"
              >
                All Products
              </Link>

              {categories.map((category) => (
                <div key={category.id} className="rounded-xl border border-[#ead9d1] p-3">
                  <Link
                    href={`/shop?category=${category.slug}`}
                    onClick={closeMenu}
                    className="block font-semibold text-[#2e221d]"
                  >
                    {category.name}
                  </Link>

                  {category.subcategories && category.subcategories.length > 0 ? (
                    <div className="mt-2 grid gap-1 pl-3">
                      {category.subcategories.map((sub) => (
                        <Link
                          key={sub.id}
                          href={`/shop?category=${category.slug}&subcategory=${sub.slug}`}
                          onClick={closeMenu}
                          className="rounded-lg px-3 py-2 text-sm text-neutral-600 hover:bg-[#f8f3ef]"
                        >
                          {sub.name}
                        </Link>
                      ))}
                    </div>
                  ) : null}
                </div>
              ))}

              <Link
                href="/track-order"
                onClick={closeMenu}
                className="rounded-xl px-4 py-3 font-semibold hover:bg-[#f8f3ef]"
              >
                Track Order
              </Link>
            </div>
          </div>
        ) : null}
      </div>
    </header>
  );
}