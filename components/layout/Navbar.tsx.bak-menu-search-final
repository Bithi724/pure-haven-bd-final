"use client";

import Link from "next/link";
import { useEffect, useState } from "react";

type Category = {
  id: number | string;
  name: string;
  slug: string;
  subcategories?: { id: number | string; name: string; slug: string }[];
};

export default function Navbar() {
  const [categories, setCategories] = useState<Category[]>([]);
  const [menuOpen, setMenuOpen] = useState(false);

  useEffect(() => {
    async function loadCategories() {
      try {
        const res = await fetch("/api/categories", { cache: "no-store" });
        const data = await res.json();

        if (res.ok && data?.success && Array.isArray(data.categories)) {
          setCategories(data.categories);
        }
      } catch {
        setCategories([]);
      }
    }

    loadCategories();
  }, []);

  function closeMenu() {
    setMenuOpen(false);
  }

  return (
    <header className="sticky top-0 z-50 border-b border-[#ead9d1] bg-[#fffaf7]/95 backdrop-blur">
      <div className="container-ph">
        <div className="grid grid-cols-[auto_1fr_auto] items-center gap-4 py-4">
          <button
            type="button"
            onClick={() => setMenuOpen((v) => !v)}
            className="grid h-12 w-12 place-items-center border border-[#ead9d1] bg-white text-2xl text-[#2e221d]"
            aria-label="Open menu"
          >
            ☰
          </button>

          <Link href="/" className="text-center" onClick={closeMenu}>
            <div className="text-3xl font-semibold tracking-[0.35em] text-[#2e221d]">
              PURE
            </div>
            <div className="mt-1 text-xs tracking-[0.45em] text-[#7a5244]">
              HAVEN BD
            </div>
          </Link>

          <div className="flex items-center gap-2">
            <Link
              href="/shop?focus=search"
              className="grid h-12 w-12 place-items-center border border-[#ead9d1] bg-white text-2xl"
              aria-label="Search"
            >
              🔍
            </Link>

            <Link
              href="/wishlist"
              className="grid h-12 w-12 place-items-center border border-[#ead9d1] bg-white text-2xl"
              aria-label="Wishlist"
            >
              ♡
            </Link>

            <Link
              href="/cart"
              className="grid h-12 w-12 place-items-center border border-[#ead9d1] bg-white text-2xl"
              aria-label="Cart"
            >
              🛒
            </Link>

            <Link
              href="/login"
              className="hidden h-12 w-12 place-items-center border border-[#ead9d1] bg-white text-2xl sm:grid"
              aria-label="Account"
            >
              ♙
            </Link>
          </div>
        </div>

        <nav className="hidden items-center justify-center gap-7 border-t border-[#ead9d1] py-4 text-sm text-[#2e221d] md:flex">
          <Link href="/shop" className="hover:text-[#7a5244]">
            All Products
          </Link>

          {categories.map((category) => (
            <div key={category.id} className="group relative">
              <Link
                href={`/shop?category=${encodeURIComponent(category.slug)}`}
                className="hover:text-[#7a5244]"
              >
                {category.name} <span className="text-xs">⌄</span>
              </Link>

              {category.subcategories && category.subcategories.length > 0 ? (
                <div className="invisible absolute left-0 top-full min-w-48 translate-y-2 rounded-2xl border border-[#ead9d1] bg-white p-3 opacity-0 shadow-lg transition group-hover:visible group-hover:translate-y-0 group-hover:opacity-100">
                  {category.subcategories.map((sub) => (
                    <Link
                      key={sub.id}
                      href={`/shop?category=${encodeURIComponent(category.slug)}&subcategory=${encodeURIComponent(sub.slug)}`}
                      className="block rounded-xl px-3 py-2 text-sm hover:bg-[#f8f3ef]"
                    >
                      {sub.name}
                    </Link>
                  ))}
                </div>
              ) : null}
            </div>
          ))}

          <Link href="/track-order" className="hover:text-[#7a5244]">
            Track Order
          </Link>
        </nav>
      </div>

      {menuOpen ? (
        <div className="fixed inset-0 z-[80] bg-black/35 md:hidden" onClick={closeMenu}>
          <div
            className="h-full w-[82%] max-w-sm bg-[#2e221d] p-6 text-white"
            onClick={(e) => e.stopPropagation()}
          >
            <div className="mb-8 flex items-center justify-between">
              <div>
                <div className="text-2xl font-semibold tracking-[0.3em]">PURE</div>
                <div className="text-xs tracking-[0.35em] text-white/70">HAVEN BD</div>
              </div>

              <button type="button" onClick={closeMenu} className="text-3xl">
                ×
              </button>
            </div>

            <div className="grid gap-4 text-lg">
              <Link href="/" onClick={closeMenu}>Home</Link>
              <Link href="/shop" onClick={closeMenu}>Shop</Link>
              <Link href="/wishlist" onClick={closeMenu}>Wishlist</Link>
              <Link href="/cart" onClick={closeMenu}>Cart</Link>
              <Link href="/track-order" onClick={closeMenu}>Track Order</Link>
              <Link href="/login" onClick={closeMenu}>Account</Link>
            </div>

            <div className="mt-10">
              <div className="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-white/70">
                Categories
              </div>

              <div className="grid gap-3 text-base">
                {categories.map((category) => (
                  <Link
                    key={category.id}
                    href={`/shop?category=${encodeURIComponent(category.slug)}`}
                    onClick={closeMenu}
                  >
                    {category.name}
                  </Link>
                ))}
              </div>
            </div>
          </div>
        </div>
      ) : null}
    </header>
  );
}
