"use client";

import Link from "next/link";
import { useEffect, useMemo, useState } from "react";
import AdminNav from "@/components/admin/AdminNav";

type OrderItem = {
  id?: number | string;
  name?: string;
  productName?: string;
  quantity?: number;
  price?: number;
  total?: number;
};

type Order = {
  id: number | string;
  customerName?: string;
  name?: string;
  phone?: string;
  customerPhone?: string;
  address?: string;
  customerAddress?: string;
  status?: string;
  paymentStatus?: string;
  paymentMethod?: string;
  trxId?: string;
  subtotal?: number;
  deliveryCharge?: number;
  total?: number;
  totalAmount?: number;
  createdAt?: string;
  items?: OrderItem[];
  orderItems?: OrderItem[];
};

const statuses = ["pending", "confirmed", "processing", "delivered", "cancelled"];

function money(value: unknown) {
  const n = Number(value || 0);
  return `${n.toLocaleString("en-BD")} BDT`;
}

function orderItems(order: Order) {
  return order.items || order.orderItems || [];
}

function itemCount(order: Order) {
  return orderItems(order).reduce((sum, item) => {
    const qty = Number(item.quantity || 1);
    return sum + qty;
  }, 0);
}

function subtotal(order: Order) {
  if (typeof order.subtotal === "number") return order.subtotal;

  return orderItems(order).reduce((sum, item) => {
    const qty = Number(item.quantity || 1);
    const price = Number(item.price || 0);
    return sum + qty * price;
  }, 0);
}

function grandTotal(order: Order) {
  return Number(order.totalAmount || order.total || 0) || subtotal(order) + Number(order.deliveryCharge || 0);
}

function dateText(value?: string) {
  if (!value) return "N/A";
  return new Date(value).toLocaleString("en-BD");
}

export default function AdminOrdersPage() {
  const [orders, setOrders] = useState<Order[]>([]);
  const [query, setQuery] = useState("");
  const [statusFilter, setStatusFilter] = useState("all");
  const [message, setMessage] = useState("");

  async function loadOrders() {
    try {
      const res = await fetch("/api/orders", { cache: "no-store" });
      const data = await res.json();

      const list: Order[] = Array.isArray(data?.orders)
        ? data.orders
        : Array.isArray(data)
        ? data
        : [];

      setOrders(list);
    } catch {
      setMessage("Failed to load orders.");
    }
  }

  useEffect(() => {
    loadOrders();
  }, []);

  const filteredOrders = useMemo(() => {
    const clean = query.trim().toLowerCase();

    return orders.filter((order) => {
      const text = [
        order.id,
        order.customerName,
        order.name,
        order.phone,
        order.customerPhone,
        order.paymentMethod,
        order.paymentStatus,
        order.trxId,
        order.status,
      ]
        .filter(Boolean)
        .join(" ")
        .toLowerCase();

      const matchQuery = !clean || text.includes(clean);
      const matchStatus =
        statusFilter === "all" || String(order.status || "pending") === statusFilter;

      return matchQuery && matchStatus;
    });
  }, [orders, query, statusFilter]);

  async function updateOrderStatus(order: Order, status: string) {
    setOrders((prev) =>
      prev.map((item) =>
        String(item.id) === String(order.id) ? { ...item, status } : item
      )
    );

    try {
      await fetch("/api/orders", {
        method: "PUT",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          id: order.id,
          status,
        }),
      });
    } catch {
      setMessage("Status changed locally, but server update may have failed.");
    }
  }

  return (
    <main className="min-h-screen bg-[#fcf8f6] px-4 py-10 text-[#2e221d]">
      <div className="mx-auto max-w-7xl space-y-8">
        <AdminNav />

        <section className="rounded-[28px] border border-[#ead9d1] bg-white p-6 shadow-sm md:p-8">
          <h1 className="text-3xl font-semibold">Orders</h1>
          <p className="mt-2 text-sm text-neutral-600">
            Manage delivery status, verify payments, and create printable vouchers.
          </p>

          {message ? (
            <div className="mt-4 rounded-2xl border border-[#ead9d1] bg-[#fffaf7] p-4 text-sm">
              {message}
            </div>
          ) : null}

          <div className="mt-6 grid gap-4 md:grid-cols-[1fr_260px]">
            <input
              value={query}
              onChange={(e) => setQuery(e.target.value)}
              className="rounded-2xl border border-[#ead9d1] px-4 py-3 outline-none"
              placeholder="Search by order ID, customer, phone, payment, trxID..."
            />

            <select
              value={statusFilter}
              onChange={(e) => setStatusFilter(e.target.value)}
              className="rounded-2xl border border-[#ead9d1] px-4 py-3 outline-none"
            >
              <option value="all">All statuses</option>
              {statuses.map((status) => (
                <option key={status} value={status}>
                  {status[0].toUpperCase() + status.slice(1)}
                </option>
              ))}
            </select>
          </div>
        </section>

        <section className="space-y-5">
          {filteredOrders.length === 0 ? (
            <div className="rounded-[28px] border border-[#ead9d1] bg-white p-8 text-center text-neutral-600">
              No orders found.
            </div>
          ) : (
            filteredOrders.map((order) => (
              <div
                key={order.id}
                className="rounded-[28px] border border-[#ead9d1] bg-white p-6 shadow-sm"
              >
                <div className="grid gap-6 lg:grid-cols-[1fr_420px]">
                  <div>
                    <div className="flex flex-wrap items-center gap-3">
                      <h2 className="text-xl font-semibold">
                        PH-{order.id}
                      </h2>

                      <span className="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">
                        Order: {order.status || "pending"}
                      </span>

                      <span className="rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700">
                        Payment: {order.paymentStatus || "pending"}
                      </span>
                    </div>

                    <div className="mt-4 space-y-1 text-sm text-neutral-700">
                      <p>
                        {(order.customerName || order.name || "N/A")} ·{" "}
                        {(order.customerPhone || order.phone || "N/A")}
                      </p>
                      <p>{order.customerAddress || order.address || "N/A"}</p>
                      <p>Method: {order.paymentMethod || "Not specified"}</p>
                      <p>{dateText(order.createdAt)}</p>
                    </div>

                    <div className="mt-8 grid gap-3 md:grid-cols-3">
                      <div className="rounded-2xl border border-[#ead9d1] p-4">
                        <p className="text-xs uppercase tracking-[0.2em] text-neutral-500">
                          Items
                        </p>
                        <p className="mt-2 text-xl font-semibold">
                          {itemCount(order)}
                        </p>
                      </div>

                      <div className="rounded-2xl border border-[#ead9d1] p-4">
                        <p className="text-xs uppercase tracking-[0.2em] text-neutral-500">
                          Subtotal
                        </p>
                        <p className="mt-2 text-xl font-semibold">
                          {money(subtotal(order))}
                        </p>
                      </div>

                      <div className="rounded-2xl border border-[#ead9d1] p-4">
                        <p className="text-xs uppercase tracking-[0.2em] text-neutral-500">
                          Grand Total
                        </p>
                        <p className="mt-2 text-xl font-semibold">
                          {money(grandTotal(order))}
                        </p>
                      </div>
                    </div>
                  </div>

                  <div>
                    <div className="mb-5 flex justify-end">
                      <Link
                        href={`/admin/orders/${order.id}/voucher`}
                        className="inline-flex min-w-[170px] items-center justify-center rounded-full bg-[#2e221d] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#7a5244]" style={{ color: "#ffffff" }}
                      >
                        Create Voucher
                      </Link>
                    </div>

                    <label className="text-xs font-semibold uppercase tracking-[0.22em] text-neutral-500">
                      Order Status
                    </label>
                    <select
                      value={order.status || "pending"}
                      onChange={(e) => updateOrderStatus(order, e.target.value)}
                      className="mt-2 w-full rounded-2xl border border-[#ead9d1] px-4 py-3 outline-none"
                    >
                      {statuses.map((status) => (
                        <option key={status} value={status}>
                          {status[0].toUpperCase() + status.slice(1)}
                        </option>
                      ))}
                    </select>

                    <div className="mt-5">
                      <p className="text-xs font-semibold uppercase tracking-[0.22em] text-neutral-500">
                        Payment Verification
                      </p>
                      <div className="mt-2 rounded-2xl border border-[#ead9d1] bg-[#fffaf7] px-4 py-3 text-sm text-neutral-700">
                        {order.paymentMethod?.toLowerCase().includes("bkash")
                          ? `bKash payment needs verification${order.trxId ? `: ${order.trxId}` : "."}`
                          : "No manual payment verification needed."}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))
          )}
        </section>
      </div>
    </main>
  );
}