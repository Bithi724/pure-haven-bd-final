@import "tailwindcss";

:root {
  --background: #fffaf7;
  --foreground: #2e221d;
  --primary: #7a5244;
  --primary-dark: #5e3d32;
  --soft: #f5e9e3;
  --soft-2: #f8f3ef;
  --border: #ead9d1;
  --muted: #6b5b55;
  --danger: #dc2626;
  --success: #15803d;
  --shadow-soft: 0 10px 30px rgba(46, 34, 29, 0.06);
}

html {
  scroll-behavior: smooth;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  background: var(--background);
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
  text-rendering: optimizeLegibility;
}

img {
  display: block;
  max-width: 100%;
}

button,
a,
input,
select,
textarea {
  transition: all 0.2s ease;
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  font: inherit;
}

input,
select,
textarea,
button {
  outline: none;
}

input::placeholder,
textarea::placeholder {
  color: #9b8a83;
}

.container-ph {
  max-width: 1280px;
  margin: 0 auto;
  padding-left: 16px;
  padding-right: 16px;
}

.section-gap {
  padding-top: 56px;
  padding-bottom: 56px;
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  border: 1px solid transparent;
  border-radius: 9999px;
  background: var(--primary);
  color: #ffffff;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 600;
  line-height: 1;
  box-shadow: var(--shadow-soft);
}

.btn-primary:hover {
  background: var(--primary-dark);
  transform: translateY(-1px);
}

.btn-primary:disabled {
  cursor: not-allowed;
  opacity: 0.6;
  transform: none;
}

.card-soft {
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: 24px;
  box-shadow: var(--shadow-soft);
}

.surface-soft {
  background: #ffffff;
  border: 1px solid var(--border);
  border-radius: 24px;
  box-shadow: var(--shadow-soft);
}

.input-soft {
  width: 100%;
  min-height: 48px;
  border: 1px solid var(--border);
  border-radius: 16px;
  background: #ffffff;
  padding: 12px 16px;
  color: var(--foreground);
}

.input-soft:focus,
select:focus,
textarea:focus {
  border-color: #caaea2;
  box-shadow: 0 0 0 3px rgba(122, 82, 68, 0.1);
}

.text-muted {
  color: var(--muted);
}

.badge-soft {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border);
  border-radius: 9999px;
  background: var(--soft-2);
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 600;
}

.empty-state {
  border: 1px solid var(--border);
  border-radius: 24px;
  background: #ffffff;
  padding: 40px 24px;
  text-align: center;
  box-shadow: var(--shadow-soft);
}

.page-title {
  font-size: clamp(2rem, 3vw, 2.5rem);
  font-weight: 700;
  line-height: 1.1;
}

.section-title {
  font-size: clamp(1.5rem, 2.4vw, 2rem);
  font-weight: 700;
  line-height: 1.15;
}

.status-success {
  color: var(--success);
}

.status-danger {
  color: var(--danger);
}

::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: #f7ede8;
}

::-webkit-scrollbar-thumb {
  background: #d5b8ab;
  border-radius: 9999px;
}

::-webkit-scrollbar-thumb:hover {
  background: #bf9b8d;
}

@media (max-width: 1024px) {
  .section-gap {
    padding-top: 48px;
    padding-bottom: 48px;
  }
}

@media (max-width: 640px) {
  .container-ph {
    padding-left: 14px;
    padding-right: 14px;
  }

  .section-gap {
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .btn-primary {
    min-height: 46px;
    padding: 11px 20px;
  }

  .card-soft,
  .surface-soft,
  .empty-state {
    border-radius: 20px;
  }
}
/* pure-haven-mobile-bottom-padding */
@media (max-width: 1023px) {
  body {
    padding-bottom: 72px;
  }
}
/* force-category-straight-rectangle */
.ph-category-section a,
.ph-category-section img,
.ph-category-section div {
  border-radius: 0 !important;
}

.ph-category-section .rounded-none {
  border-radius: 0 !important;
}
/* pure-haven-force-straight-cards-v2 */
.ph-category-section a,
.ph-category-section img,
.ph-category-section div,
.category-card,
.subcategory-card {
  border-radius: 0 !important;
}
/* Pure Haven BD: curve only Shop by Category image cards without changing layout */
a[href^="/shop?category="]:has(img) {
  border-radius: 22px !important;
  overflow: hidden !important;
}

a[href^="/shop?category="]:has(img) img {
  border-radius: 22px !important;
}

/* Strong category card rounding: remove visible old straight corners */
a[href^="/shop?category="]:has(img) {
  border-radius: 24px !important;
  overflow: hidden !important;
  clip-path: inset(0 round 24px) !important;
  background: transparent !important;
  isolation: isolate !important;
}

a[href^="/shop?category="]:has(img) > *,
a[href^="/shop?category="]:has(img) img,
a[href^="/shop?category="]:has(img) div {
  border-radius: inherit !important;
}

a[href^="/shop?category="]:has(img) img {
  display: block !important;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}

/* If the old square wrapper is visible behind the card */
div:has(> a[href^="/shop?category="]:has(img)) {
  border-radius: 24px !important;
  overflow: hidden !important;
}

/* Pure Haven BD: full responsive safety polish */
html,
body {
  max-width: 100%;
  overflow-x: hidden;
}

img,
video {
  max-width: 100%;
  height: auto;
}

.container-ph {
  width: 100%;
  max-width: 1280px;
  margin-left: auto;
  margin-right: auto;
  padding-left: clamp(14px, 4vw, 32px);
  padding-right: clamp(14px, 4vw, 32px);
}

/* Prevent long text from breaking layouts */
h1, h2, h3, h4, p, a, button, span {
  overflow-wrap: anywhere;
}

/* Product/category/admin cards should never overflow */
.card-soft,
section,
article {
  max-width: 100%;
}

/* Shop/category image cards */
a[href^="/shop?category="]:has(img) {
  border-radius: 24px !important;
  overflow: hidden !important;
  clip-path: inset(0 round 24px) !important;
}

/* Mobile bottom spacing so floating cart/nav/message does not cover content */
@media (max-width: 767px) {
  body {
    padding-bottom: 76px;
  }

  .container-ph {
    padding-left: 14px;
    padding-right: 14px;
  }

  h1 {
    font-size: clamp(28px, 8vw, 42px) !important;
    line-height: 1.1 !important;
  }

  h2 {
    font-size: clamp(24px, 7vw, 34px) !important;
    line-height: 1.15 !important;
  }

  h3 {
    font-size: clamp(18px, 5.5vw, 26px) !important;
  }

  section {
    padding-top: 28px;
    padding-bottom: 28px;
  }

  table {
    display: block;
    width: 100%;
    overflow-x: auto;
    white-space: nowrap;
  }

  input,
  select,
  textarea,
  button {
    font-size: 16px !important;
  }

  /* Admin nav scrolls nicely on mobile */
  nav div {
    max-width: 100%;
  }

  /* Floating message icon position */
  button[aria-label="Send message"] {
    right: 14px !important;
    bottom: 86px !important;
  }
}

/* Tablet layout polish */
@media (min-width: 768px) and (max-width: 1023px) {
  .container-ph {
    padding-left: 24px;
    padding-right: 24px;
  }

  section {
    padding-top: 36px;
    padding-bottom: 36px;
  }
}

/* Desktop polish */
@media (min-width: 1024px) {
  .container-ph {
    padding-left: 32px;
    padding-right: 32px;
  }
}

/* Pure Haven BD: stable mobile home hero + promo grid */
@media (max-width: 767px) {
  .ph-home-mobile-fix,
  .ph-home-mobile-fix * {
    max-width: 100%;
  }

  a[href="/shop"] img,
  a[href^="/shop?"] img {
    object-fit: cover;
  }
}

/* Category cards: keep original layout, only curved corners */
a[href^="/shop?category="]:has(img) {
  border-radius: 24px !important;
  overflow: hidden !important;
  clip-path: inset(0 round 24px) !important;
}

a[href^="/shop?category="]:has(img) img {
  border-radius: 24px !important;
}

/* Mobile bottom nav clickable fix */
.mobile-bottom-nav {
  pointer-events: auto !important;
  z-index: 9999 !important;
}

.mobile-bottom-nav a,
.mobile-bottom-nav button {
  pointer-events: auto !important;
  touch-action: manipulation !important;
}

@media (max-width: 767px) {
  body {
    padding-bottom: 82px !important;
  }

  button[aria-label="Send message"] {
    z-index: 9000 !important;
    bottom: 92px !important;
  }
}